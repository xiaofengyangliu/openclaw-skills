# 飞书开放平台应用凭证
# Feishu Open Platform App Credentials
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# 多维表格配置
# Base Configuration
FEISHU_APP_TOKEN=your_base_app_token_here
# 后端排期sheet ID，多个用逗号分隔
# Backend schedule sheet ID(s), separate multiple with comma
FEISHU_TABLE_IDS_BACKEND=
# 前端排期sheet ID，多个用逗号分隔
# Frontend schedule sheet ID(s), separate multiple with comma
FEISHU_TABLE_IDS_FRONTEND=
